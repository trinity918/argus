# Copy to .env and adjust. All services also accept equivalent CLI flags.

# NATS connection (distributed mode)
NATS_URL=nats://127.0.0.1:4222

# Audit trail location (detector writes, api reads — share the path/volume)
AUDIT_DIR=./data/audit

# --- ML scorer tunables ---
ML_WARMUP=150          # feature samples before the first Isolation Forest fit
ML_REFIT_EVERY=100     # refit cadence (samples)
ML_BUFFER=1000         # rolling training window size
ML_CONTAMINATION=0.04  # expected outlier fraction
ML_COOLDOWN_S=2.0      # per-symbol minimum seconds between ML alerts
